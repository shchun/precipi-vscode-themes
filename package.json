{
  "name": "precipi-themes",
  "displayName": "Precipi Themes",
  "description": "A curated collection of themes by precipi",
  "version": "1.0.1",
  "publisher": "precipi",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "scripts": {
    "package": "node scripts/deploy.mjs --package",
    "deploy": "node scripts/deploy.mjs"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "light",
    "orange",
    "synthwave",
    "solar",
    "emerald",
    "green",
    "amber",
    "neon"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shchun/precipi-vscode-themes"
  },
  "galleryBanner": {
    "color": "#0F0A00",
    "theme": "dark"
  },
  "contributes": {
    "themes": [
      {
        "label": "Precipi Synthwave Light",
        "uiTheme": "vs",
        "path": "./themes/precipi-synthwave-light-color-theme.json"
      },
      {
        "label": "Precipi Synthwave Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/precipi-synthwave-dark-color-theme.json"
      },
      {
        "label": "Precipi Solar Light",
        "uiTheme": "vs",
        "path": "./themes/precipi-solar-light-color-theme.json"
      },
      {
        "label": "Precipi Solar Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/precipi-solar-dark-color-theme.json"
      },
      {
        "label": "Precipi Emerald Light",
        "uiTheme": "vs",
        "path": "./themes/precipi-emerald-light-color-theme.json"
      },
      {
        "label": "Precipi Emerald Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/precipi-emerald-dark-color-theme.json"
      }
    ]
  }
}

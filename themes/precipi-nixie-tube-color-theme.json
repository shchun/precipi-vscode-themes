  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5C3A1E", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#FFD080" }
    },
    {
      "name": "String escape",
      "scope": "constant.character.escape",
      "settings": { "foreground": "#FFB347", "fontStyle": "bold" }
    },
    {
      "name": "Number / Boolean / Null",
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#FF8A1E", "fontStyle": "bold" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "keyword.operator.new"],
      "settings": { "foreground": "#FF9A2E", "fontStyle": "bold" }
    },
    {
      "name": "Storage / Type keyword",
      "scope": ["storage", "storage.type"],
      "settings": { "foreground": "#FF8A1E", "fontStyle": "bold" }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#FFB347", "fontStyle": "bold" }
    },
    {
      "name": "Function parameter",
      "scope": "variable.parameter",
      "settings": { "foreground": "#D6A668" }
    },
    {
      "name": "Class / Type name",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": { "foreground": "#66C6C0", "fontStyle": "bold" }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": { "foreground": "#99DEDA", "fontStyle": "italic" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#FFCB8A" }
    },
    {
      "name": "Built-in variable / support",
      "scope": ["variable.language", "support.variable"],
      "settings": { "foreground": "#FF9A2E" }
    },
    {
      "name": "Property / Attribute",
      "scope": ["variable.other.property", "support.type.property-name", "entity.other.attribute-name"],
      "settings": { "foreground": "#5AB6D6" }
    },
    {
      "name": "Support function",
      "scope": ["support.function", "support.function.builtin"],
      "settings": { "foreground": "#FFB347" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator.key-value"],
      "settings": { "foreground": "#FF8A1E" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#6B4A22" }
    },
    {
      "name": "Tag name",
      "scope": ["entity.name.tag", "meta.tag"],
      "settings": { "foreground": "#FF9A2E", "fontStyle": "bold" }
    },
    {
      "name": "Tag attribute",
      "scope": "entity.other.attribute-name.html",
      "settings": { "foreground": "#FFB347" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#5AB6D6" }
    },
    {
      "name": "CSS value",
      "scope": ["meta.property-value.css", "support.constant.property-value.css"],
      "settings": { "foreground": "#FFD080" }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#FF8A1E", "fontStyle": "bold" }
    },
    {
      "name": "Import / Module",
      "scope": ["keyword.control.import", "keyword.control.from", "support.module"],
      "settings": { "foreground": "#FF9A2E", "fontStyle": "bold" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#66C6C0", "fontStyle": "italic" }
    },
    {
      "name": "Type annotation",
      "scope": ["meta.type.annotation", "support.type.primitive"],
      "settings": { "foreground": "#66C6C0" }
    },
    {
      "name": "Constant",
      "scope": "variable.other.constant",
      "settings": { "foreground": "#FF8A1E", "fontStyle": "bold" }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": { "foreground": "#FF4D3D", "fontStyle": "bold underline" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#FF9A2E", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": { "foreground": "#FF8A1E", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": { "foreground": "#C79A66", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#66C6C0" }
    },
    {
      "name": "Markdown link",
      "scope": "markup.underline.link",
      "settings": { "foreground": "#FFB347", "fontStyle": "underline" }
    }
  ]
}

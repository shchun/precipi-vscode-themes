  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5C3D1E", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#FFD080" }
    },
    {
      "name": "String escape",
      "scope": "constant.character.escape",
      "settings": { "foreground": "#FF9A00", "fontStyle": "bold" }
    },
    {
      "name": "Number / Boolean / Null",
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#FF6B00", "fontStyle": "bold" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "keyword.operator.new"],
      "settings": { "foreground": "#FF9A00", "fontStyle": "bold" }
    },
    {
      "name": "Storage / Type keyword",
      "scope": ["storage", "storage.type"],
      "settings": { "foreground": "#FF6B00", "fontStyle": "bold" }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#FFBE00", "fontStyle": "bold" }
    },
    {
      "name": "Function parameter",
      "scope": "variable.parameter",
      "settings": { "foreground": "#C8A060" }
    },
    {
      "name": "Class / Type name",
      "scope": ["entity.name.class", "entity.name.type", "support.class"],
      "settings": { "foreground": "#00C8FF", "fontStyle": "bold" }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": { "foreground": "#66D4FF", "fontStyle": "italic" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#F0E6D0" }
    },
    {
      "name": "Built-in variable / support",
      "scope": ["variable.language", "support.variable"],
      "settings": { "foreground": "#FF9A00" }
    },
    {
      "name": "Property / Attribute",
      "scope": ["variable.other.property", "support.type.property-name", "entity.other.attribute-name"],
      "settings": { "foreground": "#00F5C8" }
    },
    {
      "name": "Support function",
      "scope": ["support.function", "support.function.builtin"],
      "settings": { "foreground": "#FFBE00" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.separator.key-value"],
      "settings": { "foreground": "#FF6B00" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#6B4A20" }
    },
    {
      "name": "Tag name",
      "scope": ["entity.name.tag", "meta.tag"],
      "settings": { "foreground": "#FF9A00", "fontStyle": "bold" }
    },
    {
      "name": "Tag attribute",
      "scope": "entity.other.attribute-name.html",
      "settings": { "foreground": "#FFBE00" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#00F5C8" }
    },
    {
      "name": "CSS value",
      "scope": ["meta.property-value.css", "support.constant.property-value.css"],
      "settings": { "foreground": "#FFD080" }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#FF6B00", "fontStyle": "bold" }
    },
    {
      "name": "Import / Module",
      "scope": ["keyword.control.import", "keyword.control.from", "support.module"],
      "settings": { "foreground": "#FF9A00", "fontStyle": "bold" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#FF3DC8", "fontStyle": "italic" }
    },
    {
      "name": "Type annotation",
      "scope": ["meta.type.annotation", "support.type.primitive"],
      "settings": { "foreground": "#00C8FF" }
    },
    {
      "name": "Constant",
      "scope": "variable.other.constant",
      "settings": { "foreground": "#FF6B00", "fontStyle": "bold" }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": { "foreground": "#FF2D2D", "fontStyle": "bold underline" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#FF9A00", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": { "foreground": "#FF6B00", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": { "foreground": "#C8A878", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#00F5C8" }
    },
    {
      "name": "Markdown link",
      "scope": "markup.underline.link",
      "settings": { "foreground": "#FFBE00", "fontStyle": "underline" }
    }
  ]
}
